DB_HOST=<terraform output -raw db_instance_address>
DB_PORT=5433
DB_NAME=wcallrdspostgresql17
DB_USER=dbadmin
DB_PASSWORD=<your-master-password>
# RDS: leave unset or true (TLS). SSM tunnel to RDS still needs TLS — client negotiates SSL through the tunnel.
# Only use DB_SSL=false for local Postgres / dev DB with no TLS.
# DB_SSL=false
# DB_DEBUG=true
# DB_DEBUG_LOG_PASSWORD=true
PORT=3001
